{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "title": "weather_query",
  "description": "Fetch a weather forecast for a location.",
  "properties": {
    "location": {
      "type": "object",
      "description": "The location to query.",
      "properties": {
        "latitude": {
          "type": "number",
          "description": "Latitude in decimal degrees."
        },
        "longitude": {
          "type": "number",
          "description": "Longitude in decimal degrees."
        }
      },
      "required": ["latitude", "longitude"]
    },
    "units": {
      "type": "string",
      "description": "Units for temperature.",
      "enum": ["celsius", "fahrenheit"]
    },
    "days": {
      "type": "integer",
      "description": "Number of forecast days to return."
    },
    "includeHourly": {
      "type": "boolean",
      "description": "Whether to include an hourly breakdown."
    }
  },
  "required": ["location"]
}
